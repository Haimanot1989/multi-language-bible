{
  "book": "Psalms",
  "bookNumber": 19,
  "chapter": 121,
  "verses": [
    {
      "verse": 1,
      "text": "ዓይኖቼ ወደ ተራሮች አነሣሁ፤ ረዳቴ ከወዴት ይምጣ?"
    },
    {
      "verse": 2,
      "text": "ረዳቴ ሰማይና ምድርን ከሠራ ከእግዚአብሔር ዘንድ ነው።"
    },
    {
      "verse": 3,
      "text": "እግርህን ለመናወጥ አይሰጠውም፤ የሚጠብቅህም አይተኛም።"
    },
    {
      "verse": 4,
      "text": "እነሆ፥ እስራኤልን የሚጠብቅ አይተኛም አያንቀላፋምም።"
    },
    {
      "verse": 5,
      "text": "እግዚአብሔር ይጠብቅሃል፥ እግዚአብሔርም በቀኝ እጅህ በኩል ይጋርድሃል።"
    },
    {
      "verse": 6,
      "text": "ፀሐይ በቀን አያቃጥልህም ጨረቃም በሌሊት።"
    },
    {
      "verse": 7,
      "text": "እግዚአብሔር ከክፉ ሁሉ ይጠብቅሃል፥ ነፍስህንም ይጠብቃታል።"
    },
    {
      "verse": 8,
      "text": "ከዛሬ ጀምሮ እስከ ዘላለም እግዚአብሔር መውጣትህና መግባትህን ይጠብቃል።"
    }
  ]
}